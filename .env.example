APP_NAME=ThinkNote AI
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

SECRET_KEY=replace-with-a-secure-secret-key
DATABASE_URL=sqlite:///./thinknote_ai.db

OPENAI_API_KEY=your_openai_api_key_here
WHISPER_MODEL=base
WHISPER_FALLBACK_MODEL=medium
OCR_LANGUAGE=en
OCR_MIN_CONFIDENCE=0.30
NOUGAT_COMMAND=
VISION_LANGUAGE_PROVIDER=local
VISION_LANGUAGE_MODEL=Qwen/Qwen2-VL-2B-Instruct
CLIP_MODEL=openai/clip-vit-base-patch32
REASONING_PROVIDER=openai
REASONING_MODEL=gpt-5.2
ENABLE_GPU=true
ALLOW_MODEL_DOWNLOADS=false
MAX_VISUAL_FRAMES=0
FORCE_MATH_OCR=false
FRAME_INTERVAL_SECONDS=30
FRAME_SAMPLE_SECONDS=4
SCENE_CHANGE_THRESHOLD=0.14
DUPLICATE_FRAME_THRESHOLD=0.04
MIN_FRAME_GAP_SECONDS=8
FRAME_JPEG_QUALITY=95
SAVE_ALL_SAMPLED_FRAMES=false
YTDLP_COOKIES_FILE=
YTDLP_COOKIES_FROM_BROWSER=

UPLOAD_DIR=backend/storage/uploads
AUDIO_DIR=backend/storage/audio
FRAMES_DIR=backend/storage/frames
ANNOTATED_FRAMES_DIR=backend/storage/annotated_frames
EQUATION_CROPS_DIR=backend/storage/equation_crops
RESULTS_DIR=backend/storage/results
